# Landmap MCP Server — environment variables
# Copy this file to .env and fill in your paths, or set these in claude_desktop_config.json

# Path to the provincial boundary shapefiles directory (required)
# Default: <repo_root>/shapefiles  (auto-detected relative to server.py)
LANDMAP_SHAPEFILE_DIR=C:\path\to\landmap\shapefiles

# Path where session output is written (required)
# Default: <repo_root>/output  (auto-detected relative to server.py)
LANDMAP_OUTPUT_DIR=C:\path\to\landmap\output

# Path to the directory containing gdalbuildvrt (optional)
# Only needed if QGIS is not installed in C:\Program Files\QGIS* or C:\OSGeo4W*
# Can be a directory (e.g. C:\Program Files\QGIS 3.40\bin) or full path to binary
# LANDMAP_GDAL_BIN=C:\Program Files\QGIS 3.40.15\bin
